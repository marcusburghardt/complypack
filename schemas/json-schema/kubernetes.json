{
    "openapi": "3.0.0",
    "info": {
        "title": "Platform input schema for Kubernetes resources.\nMirrors the Kubernetes API resource object shape.",
        "version": "no version"
    },
    "paths": {},
    "components": {
        "schemas": {
            "Container": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "image": {
                        "type": "string"
                    },
                    "ports": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ContainerPort"
                        }
                    },
                    "resources": {
                        "$ref": "#/components/schemas/Resources"
                    },
                    "securityContext": {
                        "$ref": "#/components/schemas/SecurityContext"
                    }
                }
            },
            "ContainerPort": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "containerPort": {
                        "type": "integer"
                    },
                    "protocol": {
                        "type": "string"
                    }
                }
            },
            "Deployment": {
                "description": "Resource-kind aliases for documentation and policy authoring",
                "type": "object",
                "properties": {
                    "apiVersion": {
                        "type": "string"
                    },
                    "kind": {
                        "type": "string"
                    },
                    "metadata": {
                        "$ref": "#/components/schemas/Metadata"
                    },
                    "spec": {
                        "type": "object",
                        "properties": {
                            "replicas": {
                                "type": "integer"
                            },
                            "template": {
                                "type": "object",
                                "properties": {
                                    "spec": {
                                        "$ref": "#/components/schemas/PodSpec"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "Metadata": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "namespace": {
                        "type": "string"
                    },
                    "labels": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "string"
                        }
                    },
                    "annotations": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "string"
                        }
                    }
                }
            },
            "Pod": {
                "type": "object",
                "properties": {
                    "apiVersion": {
                        "type": "string"
                    },
                    "kind": {
                        "type": "string"
                    },
                    "metadata": {
                        "$ref": "#/components/schemas/Metadata"
                    },
                    "spec": {
                        "$ref": "#/components/schemas/PodSpec"
                    }
                }
            },
            "PodSpec": {
                "type": "object",
                "properties": {
                    "containers": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Container"
                        }
                    },
                    "securityContext": {
                        "$ref": "#/components/schemas/SecurityContext"
                    }
                }
            },
            "Resources": {
                "type": "object",
                "properties": {
                    "limits": {
                        "type": "object"
                    },
                    "requests": {
                        "type": "object"
                    }
                }
            },
            "SecurityContext": {
                "type": "object",
                "properties": {
                    "privileged": {
                        "type": "boolean"
                    },
                    "runAsNonRoot": {
                        "type": "boolean"
                    },
                    "runAsUser": {
                        "type": "integer"
                    },
                    "appArmorProfile": {},
                    "capabilities": {
                        "type": "object",
                        "properties": {
                            "drop": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "add": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            },
            "Service": {
                "type": "object",
                "properties": {
                    "apiVersion": {
                        "type": "string"
                    },
                    "kind": {
                        "type": "string"
                    },
                    "metadata": {
                        "$ref": "#/components/schemas/Metadata"
                    },
                    "spec": {
                        "type": "object",
                        "properties": {
                            "type": {
                                "type": "string"
                            },
                            "ports": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/components/schemas/ServicePort"
                                }
                            },
                            "selector": {
                                "type": "object",
                                "additionalProperties": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            },
            "ServicePort": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "port": {
                        "type": "integer"
                    },
                    "targetPort": {
                        "oneOf": [
                            {
                                "type": "integer"
                            },
                            {
                                "type": "string"
                            }
                        ]
                    },
                    "protocol": {
                        "type": "string"
                    }
                }
            },
            "Spec": {
                "description": "Union of Deployment, Pod, and Service spec fields; all optional.",
                "type": "object",
                "properties": {
                    "replicas": {
                        "description": "Deployment",
                        "type": "integer"
                    },
                    "template": {
                        "type": "object",
                        "properties": {
                            "spec": {
                                "$ref": "#/components/schemas/PodSpec"
                            }
                        }
                    },
                    "containers": {
                        "description": "Pod and Deployment pod template",
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Container"
                        }
                    },
                    "securityContext": {
                        "$ref": "#/components/schemas/SecurityContext"
                    },
                    "type": {
                        "description": "Service",
                        "type": "string"
                    },
                    "ports": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ServicePort"
                        }
                    },
                    "selector": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    }
}
