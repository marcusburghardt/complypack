{
    "openapi": "3.0.0",
    "info": {
        "title": "Platform input schema for Ansible playbooks and task lists.\nMirrors ansible-playbook YAML structure.",
        "version": "no version"
    },
    "paths": {},
    "components": {
        "schemas": {
            "Handler": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "listen": {
                        "oneOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        ]
                    },
                    "module": {
                        "type": "string"
                    },
                    "args": {},
                    "notify": {
                        "oneOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        ]
                    }
                }
            },
            "Role": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "role": {
                        "type": "string"
                    },
                    "vars": {
                        "type": "object"
                    },
                    "tasks": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Task"
                        }
                    }
                }
            },
            "Task": {
                "type": "object",
                "properties": {
                    "name": {
                        "description": "Module FQCN or short name may appear as a task key",
                        "type": "string"
                    },
                    "module": {
                        "description": "Module FQCN or short name may appear as a task key",
                        "type": "string"
                    },
                    "args": {
                        "description": "Module FQCN or short name may appear as a task key"
                    },
                    "when": {
                        "description": "Module FQCN or short name may appear as a task key",
                        "type": "string"
                    },
                    "register": {
                        "description": "Module FQCN or short name may appear as a task key",
                        "type": "string"
                    },
                    "notify": {
                        "description": "Module FQCN or short name may appear as a task key",
                        "oneOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        ]
                    },
                    "become": {
                        "description": "Module FQCN or short name may appear as a task key",
                        "type": "boolean"
                    },
                    "become_user": {
                        "description": "Module FQCN or short name may appear as a task key",
                        "type": "string"
                    }
                },
                "additionalProperties": {
                    "description": "Module FQCN or short name may appear as a task key"
                }
            }
        }
    }
}
