{
    "openapi": "3.0.0",
    "info": {
        "title": "Platform input schema for Dockerfile analysis.\nMirrors parsed Dockerfile instruction lists from build scanners.",
        "version": "no version"
    },
    "paths": {},
    "components": {
        "schemas": {
            "Instruction": {
                "type": "object",
                "properties": {
                    "type": {
                        "description": "Instruction keyword: FROM, RUN, COPY, ADD, EXPOSE, USER, ENV, etc.",
                        "type": "string"
                    },
                    "value": {
                        "oneOf": [
                            {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            },
                            {
                                "type": "string"
                            }
                        ]
                    },
                    "flags": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "cmd": {
                        "description": "Alternate field names used by some Dockerfile parsers",
                        "type": "string"
                    }
                }
            },
            "Stage": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "base_image": {
                        "type": "string"
                    },
                    "instructions": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Instruction"
                        }
                    }
                }
            }
        }
    }
}
