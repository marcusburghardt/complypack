{"version": 2, "width": 100, "height": 30, "timestamp": 1780352427, "env": {"SHELL": "/bin/bash", "TERM": "xterm-256color"}}
[0.004641, "o", "# ComplyPack MCP Server Demo\r\n\r\n"]
[1.00602, "o", "## 1. Show help output\r\n\r\n"]
[2.016247, "o", "Start the ComplyPack MCP server on stdio transport.\r\n\r\nThe MCP server provides Gemara catalogs and platform schemas as resources\r\nto MCP clients like Claude Desktop. It reads catalogs from local file paths\r\nspecified in complypack.yaml.\r\n\r\nExample:\r\n  complypack mcp serve --config complypack.yaml\r\n\r\nThe server runs until interrupted (Ctrl+C) or the client disconnects.\r\n\r\nUsage:\r\n  complypack mcp serve [flags]\r\n\r\nFlags:\r\n      --cache-dir string   Cache directory (default: $HOME/.complypack/cache)\r\n  -c, --config string      Path to complypack.yaml config file (default \"complypack.yaml\")\r\n  -h, --help               help for serve\r\n"]
[2.016606, "o", "\r\n"]
[4.018596, "o", "## 2. Create a complypack.yaml configuration\r\n\r\n"]
[5.022288, "o", "$ cat complypack.yaml\r\n"]
[5.023549, "o", "evaluator-id: io.complytime.opa\r\nversion: 0.1.0\r\ngemara:\r\n  source: ./catalogs/controls.yaml\r\nschemas:\r\n  - path: schemas/kubernetes.cue\r\n    platform: kubernetes\r\n  - path: schemas/terraform.cue\r\n    platform: terraform\r\n"]
[5.023764, "o", "\r\n"]
[7.025646, "o", "## 3. Create a sample catalog\r\n\r\n"]
[8.031191, "o", "$ cat catalogs/controls.yaml\r\n"]
[8.03239, "o", "metadata:\r\n  id: sample-controls\r\n  version: 1.0.0\r\n  gemara-version: 0.20.0\r\n  type: ControlCatalog\r\ncontrols:\r\n  - id: AC-1\r\n    title: Access Control Policy\r\n    description: Develop and maintain access control policy\r\n"]
[8.03258, "o", "\r\n"]
[10.034563, "o", "## 4. Run the MCP server\r\n\r\n"]
[11.036914, "o", "$ complypack mcp serve &\r\n"]
[11.043868, "o", "2026/06/01 20:10:00 Starting ComplyPack MCP server...\r\n"]
[11.044, "o", "Server ready - waiting for MCP client connection\r\n"]
[14.039376, "o", "\r\n## 5. Stop the server (Ctrl+C)\r\n\r\n"]
[14.5, "o", "^C\r\n"]
[14.51, "o", "Server shutdown complete\r\n"]
[15.0, "o", "\r\n"]
[16.0, "o", "═══════════════════════════════════════════════════════════════\r\n"]
[16.5, "o", "ERROR HANDLING EXAMPLES\r\n"]
[17.0, "o", "═══════════════════════════════════════════════════════════════\r\n"]
[17.5, "o", "\r\n"]
[18.043917, "o", "## Missing Config File\r\n\r\n"]
[19.045603, "o", "$ complypack mcp serve --config nonexistent.yaml\r\n"]
[19.052706, "o", "Error: failed to create MCP server: failed to load config: failed to read config file: open nonexistent.yaml: no such file or directory\r\n"]
[19.052946, "o", "\r\n"]
[21.055305, "o", "## Missing Required Field\r\n\r\n"]
[22.059983, "o", "$ cat bad-config.yaml\r\n"]
[22.061358, "o", "gemara:\r\n  source: ./catalogs/controls.yaml\r\nschemas:\r\n  - path: schemas/kubernetes.cue\r\n    platform: kubernetes\r\n"]
[22.061572, "o", "\r\n"]
[23.063661, "o", "$ complypack mcp serve --config bad-config.yaml\r\n"]
[23.071055, "o", "Error: failed to create MCP server: failed to load config: missing required field: evaluator-id\r\n"]
[23.071294, "o", "\r\n"]
[25.073575, "o", "Demo complete!\r\n"]
